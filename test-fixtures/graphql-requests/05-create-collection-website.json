{
  "operationName": "CreateCollectionWebsite",
  "query": "mutation CreateCollection($collection: CollectionInput!) { createCollection(collection: $collection) { _id name source status metaData createdAt } }",
  "variables": {
    "collection": {
      "name": "Company Website Knowledge",
      "description": "Scraped content from marketing site",
      "source": "website",
      "chunkingDetails": {
        "strategy": "recursiveSemantic",
        "tunables": { "chunkSize": 512, "overlap": 50 }
      },
      "webcrawler": {
        "urls": ["https://www.avakado.ai"],
        "options": { "limit": 10, "maxDepth": 2 }
      },
      "isPublic": false
    }
  },
  "_meta": { "auth": "Bearer {{ACCESS_TOKEN}}", "scope": "collection:create" }
}
