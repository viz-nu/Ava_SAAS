{
  "operationName": "CreateCollectionFile",
  "query": "mutation CreateCollection($collection: CollectionInput!) { createCollection(collection: $collection) { _id name source status metaData } }",
  "variables": {
    "collection": {
      "name": "Product Documentation PDF",
      "description": "Uploaded PDF parsed via LlamaParse",
      "source": "file",
      "chunkingDetails": {
        "strategy": "recursiveStructural",
        "tunables": {}
      },
      "parserDetails": {
        "tier": "cost_effective",
        "expand": ["text", "markdown", "metadata"],
        "version": "latest",
        "source_url": "{{R2_PUBLIC_OR_SIGNED_URL_AFTER_UPLOAD}}"
      },
      "isPublic": false
    }
  },
  "_meta": {
    "auth": "Bearer {{ACCESS_TOKEN}}",
    "prerequisite": "Upload file via 07-get-upload-url.json first"
  }
}
