{
  "operationName": "CreateLeadTemplate",
  "query": "mutation CreateLeadTemplate($LeadTemplateInput: LeadTemplateInput) { createLeadTemplate(LeadTemplateInput: $LeadTemplateInput) { _id name fields isActive } }",
  "variables": {
    "LeadTemplateInput": {
      "name": "Sales Lead",
      "description": "Standard sales lead capture template",
      "isActive": true,
      "fields": {
        "name": { "type": "string", "required": true, "label": "Full Name" },
        "email": { "type": "email", "required": true, "label": "Email" },
        "phone": { "type": "phone", "required": false, "label": "Phone" },
        "company": { "type": "string", "required": false, "label": "Company" },
        "budget": { "type": "number", "required": false, "label": "Budget (USD)" }
      }
    }
  },
  "_meta": { "auth": "Bearer {{ACCESS_TOKEN}}" }
}
