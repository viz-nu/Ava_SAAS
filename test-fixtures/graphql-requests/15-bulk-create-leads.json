  "variables": {
    "dataList": [
      {
        "templateId": "{{LEAD_TEMPLATE_ID}}",
        "data": { "name": "Alice Johnson", "email": "alice@example.com", "phone": "+14155550101", "company": "Acme Inc", "budget": 5000 },
        "notes": "Inbound from website chat"
      },
      {
        "templateId": "{{LEAD_TEMPLATE_ID}}",
        "data": { "name": "Bob Smith", "email": "bob@example.com", "phone": "+14155550102", "company": "Beta Corp", "budget": 12000 },
        "notes": "Campaign list import"
      }
    ]
  },
  "_meta": { "auth": "Bearer {{ACCESS_TOKEN}}" }
}
