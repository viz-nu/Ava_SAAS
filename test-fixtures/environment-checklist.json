{
  "description": "Environment variables and external services required for full product testing",
  "core": {
    "required": true,
    "variables": [
      { "name": "PORT", "example": "4000", "purpose": "HTTP server port" },
      { "name": "MONGO_URI", "example": "mongodb://localhost:27017/ava_test", "purpose": "MongoDB connection" },
      { "name": "ACCESS_SECRET", "purpose": "JWT access token signing" },
      { "name": "REFRESH_SECRET", "purpose": "JWT refresh token signing" },
      { "name": "SERVER_URL", "example": "http://localhost:4000", "purpose": "Public base URL for webhooks" }
    ]
  },
  "ai": {
    "required": true,
    "variables": [
      { "name": "OPEN_API_KEY", "purpose": "OpenAI chat, embeddings, voice" },
      { "name": "GEMINI_API_KEY", "purpose": "Gemini voice ephemeral tokens", "required": false }
    ]
  },
  "knowledge": {
    "required": true,
    "variables": [
      { "name": "LLAMA_PARSE_API_KEY", "purpose": "Document parsing" },
      { "name": "FIRECRAWL_API_KEY", "purpose": "Website scraping" },
      { "name": "cloudflare_access_key_id", "purpose": "R2 S3-compatible storage" },
      { "name": "cloudflare_secret_access_key", "purpose": "R2 secret" },
      { "name": "s3_api_url", "purpose": "R2 endpoint URL" }
    ]
  },
  "communications": {
    "required": false,
    "variables": [
      { "name": "EMAIL_SMTP_HOST", "purpose": "Nodemailer outbound email" },
      { "name": "EMAIL_SMTP_AUTH", "purpose": "SMTP username" },
      { "name": "EMAIL_SMTP_PASS", "purpose": "SMTP password" },
      { "name": "TWILIO_AUTH_TOKEN", "purpose": "Twilio webhook validation" },
      { "name": "TWILIO_CONNECT_APP_SID", "purpose": "Twilio Connect OAuth" },
      { "name": "WA_CLIENT_ID", "purpose": "WhatsApp channel" },
      { "name": "WA_CLIENT_SECRET", "purpose": "WhatsApp channel" }
    ]
  },
  "billing": {
    "required": false,
    "variables": [
      { "name": "RAZORPAY_KEY_ID", "purpose": "Subscription payments" },
      { "name": "RAZORPAY_KEY_SECRET", "purpose": "Subscription payments" }
    ]
  },
  "auxiliary": {
    "required": true,
    "variables": [
      { "name": "WEBHOOKS_URL", "purpose": "Email verification and auxiliary triggers" },
      { "name": "BULL_URL", "purpose": "External job queue for async processing" }
    ]
  },
  "oauth": {
    "required": false,
    "variables": [
      "GOOGLE_CLIENT_ID", "GOOGLE_CLIENT_SECRET", "GOOGLE_REDIRECT_URI",
      "AzureApplicationClientId", "AzureClientSecretValue", "AZURE_REDIRECT_URI",
      "IG_ClIENT_ID", "IG_CLIENT_Secret", "IG_REDIRECT_URI",
      "wa_client_id", "wa_client_secret", "wa_redirect_uri"
    ]
  }
}
