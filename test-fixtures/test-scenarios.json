{
  "version": "1.0",
  "scenarios": [
    {
      "id": "E2E-001",
      "name": "Business Onboarding",
      "priority": "P0",
      "steps": [
        { "action": "POST /graphql", "fixture": "graphql-requests/02-register.json", "expect": "success message, verification email triggered" },
        { "action": "Verify email via WEBHOOKS_URL link", "manual": true },
        { "action": "POST /graphql", "fixture": "graphql-requests/01-login.json", "expect": "accessToken, role admin, scopes array" },
        { "action": "POST /graphql", "fixture": "graphql-requests/20-me.json", "expect": "user profile with business" }
      ]
    },
    {
      "id": "E2E-002",
      "name": "Knowledge Base — Website Collection",
      "priority": "P0",
      "prerequisites": ["E2E-001", "FIRECRAWL_API_KEY"],
      "steps": [
        { "action": "POST /graphql", "fixture": "graphql-requests/05-create-collection-website.json", "expect": "collection with status loading" },
        { "action": "Wait for Firecrawl webhook", "path": "/webhook/firecrawl", "expect": "status becomes active" },
        { "action": "POST /graphql", "fixture": "graphql-requests/05-create-collection-website.json", "note": "Query collections to verify active status" }
      ]
    },
    {
      "id": "E2E-003",
      "name": "Knowledge Base — File Collection",
      "priority": "P0",
      "prerequisites": ["E2E-001", "R2 credentials", "LLAMA_PARSE_API_KEY"],
      "steps": [
        { "action": "POST /graphql", "fixture": "graphql-requests/07-get-upload-url.json" },
        { "action": "PUT file to presigned URL", "file": "sample-files/sample.pdf" },
        { "action": "POST /graphql", "fixture": "graphql-requests/06-create-collection-file.json", "expect": "collection created, parsing initiated" }
      ]
    },
    {
      "id": "E2E-004",
      "name": "Agent Creation & Channel Deployment",
      "priority": "P0",
      "prerequisites": ["E2E-002 or E2E-003"],
      "steps": [
        { "action": "POST /graphql", "fixture": "graphql-requests/08-create-agent.json", "store": "agentId" },
        { "action": "POST /graphql", "fixture": "graphql-requests/09-create-channel-web.json", "store": "channelId" },
        { "action": "Update agent to link collection and channel", "note": "Use updateAgent mutation" }
      ]
    },
    {
      "id": "E2E-005",
      "name": "Inbound Conversation",
      "priority": "P0",
      "prerequisites": ["E2E-004"],
      "steps": [
        { "action": "Simulate webhook", "path": "/webhook/whatsapp or /webhook/telegram", "manual": true },
        { "action": "POST /graphql", "fixture": "graphql-requests/12-fetch-conversations.json", "expect": "conversation list" },
        { "action": "POST /graphql", "fixture": "graphql-requests/13-fetch-messages.json", "expect": "message history" },
        { "action": "PUT /reaction", "fixture": "rest-payloads/reaction.json" }
      ]
    },
    {
      "id": "E2E-006",
      "name": "Custom Action & Workflow",
      "priority": "P1",
      "prerequisites": ["E2E-001"],
      "steps": [
        { "action": "POST /graphql", "fixture": "graphql-requests/10-create-action.json" },
        { "action": "POST /graphql", "fixture": "graphql-requests/11-create-workflow.json" }
      ]
    },
    {
      "id": "E2E-007",
      "name": "Lead Management & Outbound Campaign",
      "priority": "P1",
      "prerequisites": ["E2E-004"],
      "steps": [
        { "action": "POST /graphql", "fixture": "graphql-requests/14-create-lead-template.json", "store": "templateId" },
        { "action": "POST /graphql", "fixture": "graphql-requests/15-bulk-create-leads.json" },
        { "action": "POST /graphql", "fixture": "graphql-requests/16-create-campaign.json" }
      ]
    },
    {
      "id": "E2E-008",
      "name": "Support Ticket Lifecycle",
      "priority": "P1",
      "steps": [
        { "action": "POST /raise-ticket", "fixture": "rest-payloads/raise-ticket.json" },
        { "action": "POST /graphql", "fixture": "graphql-requests/19-fetch-tickets.json" }
      ]
    },
    {
      "id": "E2E-009",
      "name": "Subscription & Public Plans",
      "priority": "P2",
      "steps": [
        { "action": "POST /graphql (no auth)", "fixture": "graphql-requests/03-fetch-public-plans.json" },
        { "action": "POST /graphql", "fixture": "graphql-requests/18-start-payment.json", "requires": "RAZORPAY credentials" }
      ]
    },
    {
      "id": "E2E-010",
      "name": "Voice Agent Ephemeral Token",
      "priority": "P2",
      "prerequisites": ["agentId"],
      "steps": [
        { "action": "POST /graphql (no auth)", "fixture": "graphql-requests/04-ephemeral-token.json", "expect": "realtime session token JSON" }
      ]
    }
  ]
}
